NODE_ENV=development
PORT=3000

# Database Configuration
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/btechhelpline?appName=BtechHelpline

# JWT Authentication Configuration
JWT_SECRET=your-secure-custom-jwt-key
JWT_EXPIRES_IN=7d

# Email Transporter Credentials (optional, leave blank for local console simulation)
EMAIL_USER=
EMAIL_PASS=

# Frontend Configuration
FRONTEND_URL=http://localhost:3000
