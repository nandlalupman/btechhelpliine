NODE_ENV=development
PORT=3000

# Database Configuration
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/btechhelpline?appName=BtechHelpline

# JWT Authentication Configuration
# (Leave JWT_SECRET blank/commented out to automatically generate & persist a cryptographically secure key in MongoDB settings)
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Email Transporter Credentials (optional, leave blank for local console simulation)
EMAIL_USER=
EMAIL_PASS=
# Optional sender name/email address (defaults to EMAIL_USER / noreply@btechhelpline.com value if left blank)
# EMAIL_FROM=noreply@btechhelpline.com
# EMAIL_FROM_NAME=BtechHelpline
# Optional Custom SMTP settings (defaults to Gmail port 587 if left blank)
# EMAIL_SERVICE=gmail
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_SECURE=false

# 2Factor.in SMS Gateway Integration API Key
TWO_FACTOR_API_KEY=your-actual-2factor-api-key-here


